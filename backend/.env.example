DJANGO_SECRET_KEY=change-me-to-a-random-64-character-secret-before-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# SQLite is used by default. Set DB_ENGINE=postgres to switch later.
DB_ENGINE=sqlite
DB_NAME=db.sqlite3
DB_USER=eventops
DB_PASSWORD=eventops
DB_HOST=localhost
DB_PORT=5432

# Railway PostgreSQL (preferred in production): set DATABASE_URL from Railway.
# DATABASE_URL=postgresql://user:password@host:port/dbname
# DB_SSL_REQUIRE=True
# DB_CONN_MAX_AGE=600
