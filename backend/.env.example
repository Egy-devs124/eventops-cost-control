DJANGO_SECRET_KEY=change-me-to-a-random-64-character-secret-before-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQLite is used by default. Set DB_ENGINE=postgres to switch later.
DB_ENGINE=sqlite
DB_NAME=db.sqlite3
DB_USER=eventops
DB_PASSWORD=eventops
DB_HOST=localhost
DB_PORT=5432
